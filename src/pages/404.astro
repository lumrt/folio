---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="404 — Lost in the lab"
  description="This page slipped out of the notebook. Let's get you back to safety."
>
  <main class="nf">
    <div class="container nf__inner">
      <span class="section-label">error · 404</span>
      <h1 class="nf__title">
        <em>Hypothesis</em><br />not&nbsp;found.
      </h1>
      <p class="nf__copy">
        This page slipped out of the notebook. Maybe the experiment was archived,
        or the URL was scribbled in the wrong margin.
      </p>
      <a href="/" class="btn btn--primary"
        >back to the lab <span class="arrow">→</span></a
      >
    </div>
  </main>
</Layout>

<style>
  .nf {
    min-height: 100vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 80px 0;
  }
  .nf__inner {
    max-width: 640px;
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
  }
  .nf__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(48px, 8vw, 96px);
    line-height: 1;
    letter-spacing: -0.02em;
  }
  .nf__title em {
    color: var(--accent);
    font-style: italic;
  }
  .nf__copy {
    color: var(--ink-soft);
    max-width: 44ch;
  }
</style>
