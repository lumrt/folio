---
interface Props {
  class?: string;
  color?: "ink" | "accent";
}
const { class: className = "", color = "accent" } = Astro.props;
---

<svg
  class={`scribble scribble--${color} ${className}`}
  viewBox="0 0 220 80"
  fill="none"
  aria-hidden="true"
  preserveAspectRatio="none"
>
  <path
    d="M 14 42 C 8 16, 60 6, 110 8 C 170 10, 214 18, 210 42 C 206 64, 160 74, 110 72 C 56 70, 12 64, 18 44"
    stroke="currentColor"
    stroke-width="1.6"
    stroke-linecap="round"
    fill="none"></path>
</svg>

<style>
  .scribble {
    width: 100%;
    height: 100%;
  }
  .scribble--accent {
    color: var(--accent);
  }
  .scribble--ink {
    color: var(--ink);
  }
</style>
