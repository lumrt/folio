---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  class={`venn ${className}`}
  viewBox="0 0 280 240"
  fill="none"
  aria-hidden="true"
>
  <g stroke="currentColor" stroke-width="1.2">
    <circle cx="100" cy="100" r="68" fill="currentColor" fill-opacity="0.06"></circle>
    <circle cx="180" cy="100" r="68" fill="currentColor" fill-opacity="0.06"></circle>
    <circle cx="140" cy="160" r="68" fill="currentColor" fill-opacity="0.06"></circle>
  </g>

  <g
    font-family="IBM Plex Mono, monospace"
    font-size="11"
    font-weight="500"
    fill="currentColor"
    text-anchor="middle"
    letter-spacing="1"
  >
    <text x="68" y="60">CODE</text>
    <text x="212" y="60">DATA</text>
    <text x="140" y="220">GROWTH</text>
  </g>

  <g
    font-family="Caveat, cursive"
    font-size="14"
    fill="currentColor"
    opacity="0.7"
  >
    <text x="140" y="125" text-anchor="middle">that's me ↓</text>
  </g>

  <!-- center dot -->
  <circle cx="140" cy="125" r="3" fill="currentColor"></circle>
</svg>

<style>
  .venn {
    width: 100%;
    height: auto;
    color: var(--ink);
  }
</style>
