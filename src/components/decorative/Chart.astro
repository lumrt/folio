---
interface Props {
  type: "line" | "scatter" | "bell" | "bars" | "vault" | "network" | "quantum";
  trend?: "up" | "down";
  class?: string;
}
const { type, trend = "up", class: className = "" } = Astro.props;

const lineUp =
  "M0,90 C25,82 38,72 56,68 C72,64 90,72 108,56 C130,38 150,42 170,30 C190,18 200,14 220,10";
const lineDown =
  "M0,18 C25,30 38,40 56,46 C72,52 90,56 108,68 C130,82 150,86 170,90 C190,94 200,96 220,98";
const linePath = trend === "up" ? lineUp : lineDown;

// scatter dots
const scatterDots = Array.from({ length: 32 }, (_, i) => {
  const x = (i * 7 + (i % 5) * 3) % 220;
  const y = 90 - (Math.sin(i * 0.6) * 18 + i * 1.2) - (i > 15 ? 10 : 0);
  return { x, y: Math.max(8, Math.min(95, y)), r: 1 + (i % 3) * 0.6 };
});

// chart-style types stretch to fill, icon-style types preserve aspect
const isIcon = type === "vault" || type === "network" || type === "quantum";
const aspect = isIcon ? "xMidYMid meet" : "none";

// Quantum: precompute the lattice grid + sine waves
const quantumLattice = Array.from({ length: 11 }, (_, i) =>
  Array.from({ length: 5 }, (_, j) => ({ x: 12 + i * 20, y: 18 + j * 16 }))
).flat();
---

<svg
  class={`chart chart--${type} ${className}`}
  viewBox="0 0 220 100"
  preserveAspectRatio={aspect}
  aria-hidden="true"
>
  {/* baseline grid for chart-style only */}
  {
    !isIcon && (
      <g stroke="currentColor" opacity="0.15" stroke-width="0.4">
        <line x1="0" y1="25" x2="220" y2="25" />
        <line x1="0" y1="50" x2="220" y2="50" />
        <line x1="0" y1="75" x2="220" y2="75" />
      </g>
    )
  }

  {
    type === "line" && (
      <>
        <path
          d={`${linePath} L220,100 L0,100 Z`}
          fill="currentColor"
          opacity="0.08"
        />
        <path
          d={linePath}
          fill="none"
          stroke="currentColor"
          stroke-width="1.6"
          stroke-linecap="round"
          class="chart-line"
        />
        <circle cx="220" cy={trend === "up" ? 10 : 98} r="3" fill="currentColor" />
      </>
    )
  }

  {
    type === "scatter" &&
      scatterDots.map((d) => (
        <circle cx={d.x} cy={d.y} r={d.r} fill="currentColor" opacity="0.7" />
      ))
  }
  {type === "scatter" && (
    <path
      d="M0,80 L220,18"
      fill="none"
      stroke="currentColor"
      stroke-dasharray="3 3"
      stroke-width="0.8"
      opacity="0.6"
    />
  )}

  {
    type === "bell" && (
      <>
        <path
          d="M0,98 C40,98 70,90 90,60 C100,42 110,18 110,18 C110,18 120,42 130,60 C150,90 180,98 220,98 Z"
          fill="currentColor"
          opacity="0.12"
        />
        <path
          d="M0,98 C40,98 70,90 90,60 C100,42 110,18 110,18 C110,18 120,42 130,60 C150,90 180,98 220,98"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
        />
        <line
          x1="110"
          y1="18"
          x2="110"
          y2="98"
          stroke="currentColor"
          stroke-dasharray="2 2"
          stroke-width="0.7"
          opacity="0.6"
        />
      </>
    )
  }

  {
    type === "bars" &&
      [12, 22, 18, 30, 26, 38, 32, 50, 44, 60, 55, 72, 70, 88].map((h, i) => (
        <rect
          x={i * 16 + 4}
          y={100 - h}
          width="10"
          height={h}
          fill="currentColor"
          opacity={i % 2 === 0 ? 0.85 : 0.55}
        />
      ))
  }

  {
    /* === VAULT (Kovault): line-art safe with a combination dial === */
    type === "vault" && (
      <g stroke="currentColor" fill="none" stroke-width="1">
        {/* Outer body */}
        <rect x="32" y="14" width="156" height="76" rx="2" />
        {/* Inner door */}
        <rect
          x="42"
          y="22"
          width="136"
          height="60"
          rx="1.5"
          stroke-dasharray="2 2.5"
          stroke-opacity="0.5"
        />
        {/* Door panel separator */}
        <line
          x1="110"
          y1="22"
          x2="110"
          y2="82"
          stroke-dasharray="1.5 2"
          stroke-opacity="0.3"
        />
        {/* Combination dial — left of center */}
        <circle cx="78" cy="52" r="20" />
        <circle cx="78" cy="52" r="13" stroke-dasharray="2 2" stroke-opacity="0.7" />
        <circle cx="78" cy="52" r="3" fill="currentColor" />
        {/* Dial pointer */}
        <line
          x1="78"
          y1="52"
          x2="78"
          y2="36"
          stroke-width="1.4"
          class="vault-pointer"
        />
        {/* Dial cardinal ticks */}
        <g stroke-width="1">
          <line x1="78" y1="30" x2="78" y2="33" />
          <line x1="78" y1="71" x2="78" y2="74" />
          <line x1="56" y1="52" x2="59" y2="52" />
          <line x1="97" y1="52" x2="100" y2="52" />
        </g>
        {/* Handle on the right side of the door */}
        <line x1="142" y1="52" x2="172" y2="52" stroke-width="2" />
        <circle cx="142" cy="52" r="4" fill="currentColor" />
        <line x1="172" y1="48" x2="176" y2="56" stroke-width="2" />
        {/* Hinges */}
        <rect x="34" y="22" width="3" height="6" fill="currentColor" stroke="none" />
        <rect x="34" y="76" width="3" height="6" fill="currentColor" stroke="none" />
        {/* Annotations */}
        <g
          font-family="IBM Plex Mono, monospace"
          font-size="6.5"
          fill="currentColor"
          stroke="none"
          opacity="0.55"
          letter-spacing="0.6"
        >
          <text x="110" y="10" text-anchor="middle">MULTISIG · 3/5</text>
          <text x="155" y="98" text-anchor="middle">ledger-signed</text>
        </g>
      </g>
    )
  }

  {
    /* === NETWORK (Discord bot): mesh of nodes with a tx flowing === */
    type === "network" && (
      <g stroke="currentColor" stroke-width="0.8">
        {/* Connection lines (background mesh) */}
        <g opacity="0.45" fill="none">
          <line x1="38" y1="28" x2="110" y2="50" />
          <line x1="38" y1="78" x2="110" y2="50" />
          <line x1="182" y1="28" x2="110" y2="50" />
          <line x1="182" y1="78" x2="110" y2="50" />
          <line x1="78" y1="14" x2="110" y2="50" stroke-dasharray="1.5 2" />
          <line x1="142" y1="14" x2="110" y2="50" stroke-dasharray="1.5 2" />
          <line x1="78" y1="92" x2="110" y2="50" stroke-dasharray="1.5 2" />
          <line x1="142" y1="92" x2="110" y2="50" stroke-dasharray="1.5 2" />
          {/* Inter-node connections */}
          <line x1="38" y1="28" x2="78" y2="14" />
          <line x1="78" y1="14" x2="142" y2="14" />
          <line x1="142" y1="14" x2="182" y2="28" />
          <line x1="182" y1="28" x2="182" y2="78" />
          <line x1="182" y1="78" x2="142" y2="92" />
          <line x1="142" y1="92" x2="78" y2="92" />
          <line x1="78" y1="92" x2="38" y2="78" />
          <line x1="38" y1="78" x2="38" y2="28" />
        </g>
        {/* Outer nodes */}
        <g fill="var(--bg-card)">
          <circle cx="38" cy="28" r="4" />
          <circle cx="38" cy="78" r="4" />
          <circle cx="182" cy="28" r="4" />
          <circle cx="182" cy="78" r="4" />
          <circle cx="78" cy="14" r="3" />
          <circle cx="142" cy="14" r="3" />
          <circle cx="78" cy="92" r="3" />
          <circle cx="142" cy="92" r="3" />
        </g>
        {/* Bot in center (filled) */}
        <circle cx="110" cy="50" r="7" fill="currentColor" stroke="none" />
        <circle
          cx="110"
          cy="50"
          r="11"
          fill="none"
          stroke-dasharray="1.5 2"
          opacity="0.6"
        />
        {/* Animated tx token */}
        <circle r="2.5" fill="currentColor" stroke="none" class="net-token" />
        {/* Annotations */}
        <g
          font-family="IBM Plex Mono, monospace"
          font-size="6.5"
          fill="currentColor"
          stroke="none"
          opacity="0.55"
          letter-spacing="0.6"
        >
          <text x="110" y="6" text-anchor="middle">COMMUNITY · DISCORD</text>
          <text x="110" y="98" text-anchor="middle">↳ smooth tx via @user</text>
        </g>
      </g>
    )
  }

  {
    /* === QUANTUM (Research): wave function on a lattice === */
    type === "quantum" && (
      <>
        {/* Lattice of dots */}
        <g fill="currentColor" opacity="0.22" stroke="none">
          {quantumLattice.map((d) => (
            <circle cx={d.x} cy={d.y} r="0.7" />
          ))}
        </g>
        {/* Reference axis */}
        <line
          x1="6"
          y1="50"
          x2="214"
          y2="50"
          stroke="currentColor"
          stroke-width="0.6"
          stroke-dasharray="2 3"
          opacity="0.45"
        />
        {/* Carrier wave (smooth sine) */}
        <path
          d="M0,50 Q14,18 28,50 T56,50 T84,50 T112,50 T140,50 T168,50 T196,50 T220,50"
          fill="none"
          stroke="currentColor"
          stroke-width="1.4"
          class="q-wave-1"
        />
        {/* Modulating wave (denser, dashed — "post-quantum") */}
        <path
          d="M0,50 Q9,72 18,50 T36,50 T54,50 T72,50 T90,50 T108,50 T126,50 T144,50 T162,50 T180,50 T198,50 T220,50"
          fill="none"
          stroke="currentColor"
          stroke-width="1"
          stroke-dasharray="2 2"
          opacity="0.7"
          class="q-wave-2"
        />
        {/* Bloch-style vector at right */}
        <g transform="translate(190 50)" stroke="currentColor" fill="none">
          <circle r="9" stroke-width="0.6" stroke-dasharray="1 2" opacity="0.6" />
          <ellipse cx="0" cy="0" rx="9" ry="3" stroke-width="0.4" opacity="0.5" />
          <line
            x1="0"
            y1="0"
            x2="6"
            y2="-7"
            stroke-width="1.2"
            class="q-vector"
          />
          <polygon points="6,-7 4,-5 8,-4" fill="currentColor" stroke="none" />
          <circle cx="0" cy="0" r="1.2" fill="currentColor" stroke="none" />
        </g>
        {/* Annotations */}
        <g
          font-family="IBM Plex Mono, monospace"
          font-size="6.5"
          fill="currentColor"
          stroke="none"
          opacity="0.6"
          letter-spacing="0.6"
        >
          <text x="6" y="10">|ψ⟩ = α|0⟩ + β|1⟩</text>
          <text x="6" y="96">ML-DSA · post-quantum</text>
        </g>
      </>
    )
  }
</svg>

<style>
  .chart {
    width: 100%;
    height: 100%;
    color: var(--ink);
  }
  .chart-line {
    stroke-dasharray: 320;
    stroke-dashoffset: 320;
    animation: draw 1.6s ease-out forwards;
  }
  @keyframes draw {
    to {
      stroke-dashoffset: 0;
    }
  }

  /* Vault: dial pointer subtle rotation */
  .vault-pointer {
    transform-box: fill-box;
    transform-origin: 50% 100%;
    animation: dial 6s ease-in-out infinite;
  }
  @keyframes dial {
    0%,
    100% {
      transform: rotate(-18deg);
    }
    50% {
      transform: rotate(28deg);
    }
  }

  /* Network: token travelling between two nodes */
  .net-token {
    animation: travel 3.6s linear infinite;
    offset-path: path(
      "M 38 28 L 110 50 L 182 78 L 110 50 L 78 14 L 110 50 L 142 92 L 110 50"
    );
  }
  @keyframes travel {
    to {
      offset-distance: 100%;
    }
  }

  /* Quantum: subtle wave drift */
  .q-wave-1,
  .q-wave-2 {
    stroke-dasharray: 600;
    stroke-dashoffset: 600;
    animation: draw-q 2.2s ease-out forwards;
  }
  .q-wave-2 {
    animation-delay: 0.2s;
    stroke-dasharray: 2 2;
    animation: none;
    opacity: 0.7;
  }
  @keyframes draw-q {
    to {
      stroke-dashoffset: 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .chart-line,
    .vault-pointer,
    .net-token,
    .q-wave-1 {
      animation: none !important;
      stroke-dashoffset: 0 !important;
    }
  }
</style>
