---
import { site } from "../data/site";
const nav = [
  { label: "About", href: "#about" },
  { label: "Projects", href: "#projects" },
  { label: "Stack", href: "#stack" },
  { label: "Contact", href: "#contact" },
];
---

<header class="hd">
  <div class="container hd__inner">
    <a href="#top" class="hd__logo" aria-label="Home">
      <span class="hd__slash">/</span>{site.handle}
      <span class="hd__cursor" aria-hidden="true"></span>
    </a>

    <nav class="hd__nav" aria-label="Primary">
      {
        nav.map((item) => (
          <a class="hd__link" href={item.href}>
            {item.label}
          </a>
        ))
      }
    </nav>

    <button class="hd__burger" aria-label="Open menu" data-burger>
      <span></span><span></span><span></span>
    </button>
  </div>

  <div class="hd__rule"></div>

  <div class="hd__menu" data-menu>
    {
      nav.map((item) => (
        <a class="hd__mlink" href={item.href} data-mlink>
          {item.label}
        </a>
      ))
    }
  </div>
</header>

<script>
  const burger = document.querySelector<HTMLButtonElement>("[data-burger]");
  const menu = document.querySelector<HTMLDivElement>("[data-menu]");
  const links = document.querySelectorAll<HTMLAnchorElement>("[data-mlink]");

  burger?.addEventListener("click", () => {
    const open = menu?.classList.toggle("is-open");
    burger.classList.toggle("is-open", open);
    burger.setAttribute("aria-label", open ? "Close menu" : "Open menu");
    document.body.style.overflow = open ? "hidden" : "";
  });
  links.forEach((l) =>
    l.addEventListener("click", () => {
      menu?.classList.remove("is-open");
      burger?.classList.remove("is-open");
      document.body.style.overflow = "";
    })
  );
</script>

<style>
  .hd {
    position: sticky;
    top: 0;
    z-index: 50;
    background: color-mix(in srgb, var(--bg) 92%, transparent);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }
  .hd__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 60px;
    gap: 24px;
  }
  .hd__logo {
    font-family: var(--font-mono);
    font-weight: 600;
    font-size: 14px;
    letter-spacing: 0.02em;
    display: inline-flex;
    align-items: baseline;
    gap: 1px;
  }
  .hd__slash {
    color: var(--accent);
    margin-right: 1px;
  }
  .hd__cursor {
    display: inline-block;
    width: 7px;
    height: 14px;
    margin-left: 4px;
    background: var(--ink);
    transform: translateY(2px);
    animation: blink 1.05s steps(2, end) infinite;
  }
  @keyframes blink {
    50% {
      opacity: 0;
    }
  }

  .hd__nav {
    display: none;
    gap: 28px;
  }
  .hd__link {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    position: relative;
    padding: 4px 0;
    transition: color 0.18s ease;
  }
  .hd__link::after {
    content: "";
    position: absolute;
    inset: auto 0 0 0;
    height: 1px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.25s ease;
  }
  .hd__link:hover {
    color: var(--ink);
  }
  .hd__link:hover::after {
    transform: scaleX(1);
  }

  .hd__rule {
    height: 1px;
    background: linear-gradient(
      to right,
      var(--rule) 0,
      var(--rule) 4px,
      transparent 4px,
      transparent 8px
    );
    background-size: 8px 1px;
  }

  .hd__burger {
    display: inline-flex;
    flex-direction: column;
    gap: 5px;
    width: 28px;
    height: 28px;
    align-items: center;
    justify-content: center;
  }
  .hd__burger span {
    display: block;
    width: 22px;
    height: 1.5px;
    background: var(--ink);
    transition: transform 0.25s ease;
  }
  .hd__burger.is-open span:nth-child(1) {
    transform: translateY(6.5px) rotate(45deg);
  }
  .hd__burger.is-open span:nth-child(2) {
    opacity: 0;
  }
  .hd__burger.is-open span:nth-child(3) {
    transform: translateY(-6.5px) rotate(-45deg);
  }

  .hd__menu {
    position: fixed;
    inset: 60px 0 0 0;
    background: var(--bg);
    padding: 32px var(--gutter);
    display: flex;
    flex-direction: column;
    gap: 20px;
    transform: translateY(-12px);
    opacity: 0;
    pointer-events: none;
    transition:
      opacity 0.2s ease,
      transform 0.25s ease;
    border-top: 1px solid var(--rule);
  }
  .hd__menu.is-open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .hd__mlink {
    font-family: var(--font-serif);
    font-size: 36px;
    line-height: 1;
    color: var(--ink);
  }
  .hd__mlink--accent {
    font-family: var(--font-mono);
    font-size: 14px;
    color: var(--accent);
    margin-top: auto;
  }

  @media (min-width: 760px) {
    .hd__nav {
      display: inline-flex;
    }
    .hd__burger {
      display: none;
    }
    .hd__menu {
      display: none;
    }
  }
</style>
