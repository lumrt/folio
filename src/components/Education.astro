---
import { education } from "../data/site";
---

<section id="education" class="edu reveal">
  <div class="container">
    <header class="edu__head">
      <span class="section-label">credentials</span>
      <h2 class="edu__title">
        Formal training & <em>verified</em> knowledge.
      </h2>
    </header>

    <div class="dashed-rule" style="margin: 24px 0 28px"></div>

    <ul class="edu__list">
      {
        education.map((e, i) => {
          const interactive = !!(e.image || e.url);
          const Tag = e.image ? "button" : e.url ? "a" : "div";
          const tagProps = e.image
            ? {
                type: "button" as const,
                "data-cert-image": e.image,
                "data-cert-title": `${e.title} — ${e.org}`,
                "aria-label": `Open ${e.title} certificate`,
              }
            : e.url
              ? {
                  href: e.url,
                  target: "_blank",
                  rel: "noopener noreferrer",
                  "aria-label": `Open ${e.title}`,
                }
              : {};
          return (
            <li class="edu-item">
              <Tag class={`edu-card${interactive ? " edu-card--link" : ""}`} {...tagProps}>
                <header class="edu-card__head">
                  <span class={`edu-card__kind edu-card__kind--${e.kind}`}>
                    {e.kind === "school" ? "school" : "certification"}
                  </span>
                  <span class="edu-card__code">{e.code}</span>
                </header>

                <h3 class="edu-card__title">{e.title}</h3>
                <p class="edu-card__org">
                  <span>{e.org}</span>
                  <span class="edu-card__sep">·</span>
                  <span class="edu-card__period">{e.period}</span>
                </p>

                <p class="edu-card__blurb">{e.blurb}</p>

                {interactive && (
                  <span class="edu-card__visit" aria-hidden="true">
                    {e.image
                      ? "view certificate"
                      : e.kind === "school"
                        ? "school site"
                        : "verify"}{" "}
                    <span class="arrow">{e.image ? "→" : "↗"}</span>
                  </span>
                )}

                <span class="edu-card__index">
                  {String(i + 1).padStart(2, "0")}
                </span>
              </Tag>
            </li>
          );
        })
      }
    </ul>
  </div>

  <!-- Certificate modal — hidden by default, opened by [data-cert-image] buttons -->
  <div class="cert-modal" data-cert-modal hidden aria-hidden="true" role="dialog" aria-modal="true" aria-labelledby="cert-modal-title">
    <button class="cert-modal__backdrop" data-cert-close aria-label="Close certificate"></button>
    <figure class="cert-modal__inner">
      <header class="cert-modal__head">
        <span class="cert-modal__label" id="cert-modal-title">certificate</span>
        <button class="cert-modal__close" data-cert-close aria-label="Close">×</button>
      </header>
      <img class="cert-modal__img" data-cert-img alt="" />
      <figcaption class="cert-modal__cap" data-cert-cap></figcaption>
    </figure>
  </div>
</section>

<script>
  const modal = document.querySelector<HTMLDivElement>("[data-cert-modal]");
  const modalImg = modal?.querySelector<HTMLImageElement>("[data-cert-img]");
  const modalCap = modal?.querySelector<HTMLElement>("[data-cert-cap]");
  const modalTitle = modal?.querySelector<HTMLElement>("#cert-modal-title");
  const triggers = document.querySelectorAll<HTMLButtonElement>("[data-cert-image]");
  const closers = modal?.querySelectorAll<HTMLElement>("[data-cert-close]");

  let lastTrigger: HTMLElement | null = null;

  const open = (trigger: HTMLButtonElement) => {
    if (!modal || !modalImg || !modalCap || !modalTitle) return;
    const src = trigger.dataset.certImage!;
    const title = trigger.dataset.certTitle ?? "certificate";
    modalImg.src = src;
    modalImg.alt = title;
    modalCap.textContent = title;
    modalTitle.textContent = title;
    lastTrigger = trigger;
    modal.hidden = false;
    requestAnimationFrame(() => modal.classList.add("is-open"));
    modal.setAttribute("aria-hidden", "false");
    document.body.style.overflow = "hidden";
  };

  const close = () => {
    if (!modal) return;
    modal.classList.remove("is-open");
    modal.setAttribute("aria-hidden", "true");
    document.body.style.overflow = "";
    // Wait for the CSS transition before fully hiding so we can re-open later
    setTimeout(() => {
      modal.hidden = true;
    }, 200);
    lastTrigger?.focus();
  };

  triggers.forEach((t) => t.addEventListener("click", () => open(t)));
  closers?.forEach((c) => c.addEventListener("click", close));
  document.addEventListener("keydown", (e) => {
    if (e.key === "Escape" && modal && !modal.hidden) close();
  });
</script>

<style>
  .edu {
    padding: clamp(24px, 5vw, 56px) 0 clamp(40px, 6vw, 72px);
  }
  .edu__head {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .edu__title {
    font-family: var(--font-serif);
    font-weight: 500;
    font-size: clamp(36px, 5.5vw, 64px);
    line-height: 1;
    letter-spacing: -0.015em;
  }
  .edu__title em {
    font-style: italic;
    color: var(--ink-soft);
  }

  .edu__list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: 1fr;
    gap: 16px;
  }
  @media (min-width: 760px) {
    .edu__list {
      grid-template-columns: 1fr 1fr;
    }
  }

  .edu-item {
    display: flex;
  }

  .edu-card {
    flex: 1;
    border: 1px solid var(--rule);
    background: var(--bg-card);
    padding: 22px;
    position: relative;
    display: flex;
    flex-direction: column;
    color: inherit;
    text-decoration: none;
    transition:
      transform 0.25s ease,
      box-shadow 0.25s ease;
    /* normalize <button> rendering so cert cards match school cards */
    font: inherit;
    text-align: left;
    width: 100%;
    cursor: default;
  }
  .edu-card--link {
    cursor: pointer;
  }
  .edu-card--link:hover {
    transform: translateY(-3px);
    box-shadow: 6px 6px 0 -2px rgba(184, 57, 44, 0.18);
  }

  .edu-card__head {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 12px;
  }
  .edu-card__kind {
    font-family: var(--font-mono);
    font-size: 9px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    padding: 4px 8px;
    border: 1px solid currentColor;
  }
  .edu-card__kind--school {
    color: var(--highlight);
  }
  .edu-card__kind--cert {
    color: var(--accent);
  }
  .edu-card__code {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--ink-mute);
  }

  .edu-card__title {
    font-family: var(--font-serif);
    font-weight: 600;
    font-size: 30px;
    line-height: 1.05;
    letter-spacing: -0.01em;
  }
  .edu-card__org {
    margin-top: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-soft);
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    align-items: baseline;
  }
  .edu-card__sep {
    color: var(--ink-mute);
  }
  .edu-card__period {
    color: var(--ink-mute);
  }

  .edu-card__blurb {
    margin-top: 14px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--ink-soft);
    line-height: 1.55;
    flex: 1;
  }

  .edu-card__visit {
    margin-top: 16px;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: lowercase;
    letter-spacing: 0.04em;
    color: var(--accent);
    transition: transform 0.18s ease;
  }
  .edu-card--link:hover .edu-card__visit {
    transform: translateX(3px);
  }
  .edu-card__index {
    position: absolute;
    bottom: 12px;
    right: 14px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--ink-mute);
    letter-spacing: 0.1em;
  }

  /* === Certificate modal === */
  .cert-modal {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: grid;
    place-items: center;
    padding: clamp(16px, 4vw, 48px);
    opacity: 0;
    transition: opacity 0.18s ease;
  }
  .cert-modal.is-open {
    opacity: 1;
  }
  .cert-modal[hidden] {
    display: none;
  }
  .cert-modal__backdrop {
    position: absolute;
    inset: 0;
    background: rgba(20, 20, 18, 0.72);
    border: 0;
    padding: 0;
    margin: 0;
    cursor: zoom-out;
  }
  .cert-modal__inner {
    position: relative;
    margin: 0;
    max-width: min(960px, 100%);
    background: var(--bg);
    border: 1px solid var(--ink);
    box-shadow:
      0 10px 0 -4px rgba(184, 57, 44, 0.4),
      0 30px 80px -20px rgba(0, 0, 0, 0.5);
    transform: translateY(8px) scale(0.98);
    transition:
      transform 0.22s ease,
      opacity 0.18s ease;
  }
  .cert-modal.is-open .cert-modal__inner {
    transform: translateY(0) scale(1);
  }
  .cert-modal__head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    padding: 12px 16px;
    border-bottom: 1px dashed var(--rule);
  }
  .cert-modal__label {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.16em;
    color: var(--ink-mute);
  }
  .cert-modal__close {
    border: 0;
    background: transparent;
    color: var(--ink);
    font-size: 24px;
    line-height: 1;
    cursor: pointer;
    padding: 4px 8px;
    transition: color 0.15s ease;
  }
  .cert-modal__close:hover {
    color: var(--accent);
  }
  .cert-modal__img {
    display: block;
    width: 100%;
    height: auto;
    max-height: 78vh;
    object-fit: contain;
    background: var(--bg-soft);
  }
  .cert-modal__cap {
    padding: 10px 16px 14px;
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--ink-mute);
    letter-spacing: 0.04em;
  }

  @media (prefers-reduced-motion: reduce) {
    .cert-modal,
    .cert-modal__inner {
      transition: none;
    }
  }
</style>
