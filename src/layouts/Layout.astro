---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "/folio — engineer · scientist · operator",
  description = "I turn product hypotheses into shipped software that compounds. Available for short missions and long-term remote roles.",
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="generator" content={Astro.generator} />

    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="theme-color" content="#f1ece1" />
    <meta name="color-scheme" content="light dark" />

    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="canonical" href={Astro.url.toString()} />

    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, viewport-fit=cover"
    />
  </head>
  <body>
    <a href="#top" class="skip">skip to content</a>
    <slot />

    <script>
      // === Reveal-on-scroll using IntersectionObserver ===
      const observer = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("is-visible");
              observer.unobserve(e.target);
            }
          }
        },
        { threshold: 0.12, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll(".reveal").forEach((el) => observer.observe(el));
    </script>

    <style is:global>
      .skip {
        position: absolute;
        left: -9999px;
        top: 0;
      }
      .skip:focus {
        left: 16px;
        top: 12px;
        background: var(--ink);
        color: var(--bg);
        padding: 8px 12px;
        z-index: 100;
      }
    </style>
  </body>
</html>
